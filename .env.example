ETHERSCAN_API_KEY="" # https://etherscan.io/apidashboard

# ── Railway MCP service ──────────────────────────────────────────────────────
# Copy needed vars to .env.local (gitignored). Bun auto-loads .env.local.

# Postgres. Local default matches docker-compose; Railway injects its own.
DATABASE_URL="postgres://redlens:redlens@localhost:5432/redlens"

# OpenRouter — semantic search embeddings (sync:embeddings + query-time).
# Without this, semantic search is silently empty; lexical still works.
OPENROUTER_API_KEY=""

# Optional overrides (defaults in src/server/config.ts):
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# EMBED_MODEL="qwen/qwen3-embedding-8b"
# EMBED_DIM="1024"
# EMBED_BATCH="50"
# PORT="3000"
# MCP_PATH="/mcp"