ETHERSCAN_API_KEY="" # https://etherscan.io/apidashboard

# ── Railway MCP service ──────────────────────────────────────────────────────
# Copy needed vars to .env.local (gitignored). Bun auto-loads .env.local.

# Postgres. Local default matches docker-compose; Railway injects its own.
DATABASE_URL="postgres://redlens:redlens@localhost:5432/redlens"
ATLAS_UPDATE_ENABLED=1

# OpenRouter — semantic search embeddings (sync:embeddings + query-time).
# Without this, semantic search is silently empty; lexical still works.
OPENROUTER_API_KEY=""

# ── Auth (GitHub OAuth + JWT session) ────────────────────────────────────────
# Create a GitHub OAuth App (Settings → Developer settings → OAuth Apps).
# Authorization callback URL = <APP_URL>/api/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Random secret signing the session JWT. Generate: openssl rand -hex 32
CHAT_JWT_SECRET=""

# Optional overrides (defaults in src/server/config.ts):
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# EMBED_MODEL="qwen/qwen3-embedding-8b"
# EMBED_BATCH="50"
# PORT="3000"
# MCP_PATH="/mcp"
# APP_URL="http://localhost:3000"   # public origin; Railway derives from RAILWAY_PUBLIC_DOMAIN
