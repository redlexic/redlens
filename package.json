{
  "name": "lens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/aux/dev.mjs",
    "dev:vite": "vite",
    "dev:server": "bun src/server/index.ts",
    "build:index": "node --env-file-if-exists=.env.local scripts/required/build-index.mjs",
    "build:glossary": "node scripts/required/build-glossary.mjs",
    "build:addresses": "node --env-file-if-exists=.env.local scripts/required/build-addresses.mjs",
    "build:snapshot": "node --env-file-if-exists=.env.local scripts/required/fetch-snapshots.mjs",
    "build:graph": "node scripts/required/build-graph.mjs",
    "build:rag": "node --env-file-if-exists=.env.local scripts/required/build-rag.mjs",
    "build:forum-cache": "node scripts/required/build-forum-cache.mjs",
    "build:history": "pnpm build:forum-cache && node scripts/required/build-history.mjs",
    "sync:history:local": "node scripts/required/sync-history.mjs",
    "sync:history:remote": "node scripts/required/sync-history.mjs --remote",
    "build:manifest": "node scripts/required/build-manifest.mjs",
    "processes:check": "node scripts/required/check-processes-dirty.mjs",
    "processes:triage": "bash scripts/aux/processes-triage.sh",
    "processes:apply-decisions": "node scripts/aux/processes-apply-decisions.mjs",
    "processes:bootstrap": "node scripts/aux/processes-bootstrap.mjs",
    "build:at": "node --env-file-if-exists=.env.local scripts/required/build-at.mjs",
    "build:ts": "tsc -b",
    "build:vite": "vite build",
    "build:railway": "bun scripts/required/build-index.mjs && bun scripts/required/build-graph.mjs && bun scripts/required/build-manifest.mjs && bun run build:ts && bun run build:vite",
    "build": "pnpm build:index && pnpm build:glossary && pnpm build:addresses && pnpm build:snapshot && pnpm build:graph && pnpm build:manifest && pnpm run build:ts && vite build",
    "build:server": "pnpm build:index && pnpm build:graph && pnpm build:rag",
    "start": "bun src/server/index.ts",
    "refresh:atlas-build": "bun scripts/required/refresh-atlas-build.mjs",
    "sync:atlas": "bun src/server/sync.ts",
    "sync:embeddings": "bun src/server/sync-embeddings.ts",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "bun src/server/migrate.ts",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "bun test src/server",
    "test:snap": "vitest run --config vitest.snap.config.ts",
    "test:snap:update": "vitest run --config vitest.snap.config.ts -u",
    "check:pr": "bash scripts/aux/check-atlas-pr.sh",
    "tva": "bash scripts/aux/tva.sh",
    "knip": "knip",
    "pull-atlas": "git submodule update --init --recursive"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@uiw/react-color": "^2.10.1",
    "@xyflow/react": "^12.10.2",
    "arctic": "^3.7.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-traversal": "^0.3.1",
    "jose": "^6.2.3",
    "katex": "^0.16.45",
    "minisearch": "^7.2.0",
    "openai": "^6.39.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.1.0",
    "wcag-contrast": "3.0.0",
    "workbox-window": "^7.4.1",
    "wouter": "^3.9.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wcag-contrast": "^3.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.2.0",
    "jsdom": "^29.1.1",
    "knip": "^6.6.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "viem": "^2.48.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node",
      "protobufjs"
    ]
  }
}
