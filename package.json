{
  "name": "lens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:index": "node --env-file-if-exists=.env.local scripts/required/build-index.mjs",
    "build:glossary": "node scripts/required/build-glossary.mjs",
    "build:addresses": "node --env-file-if-exists=.env.local scripts/required/build-addresses.mjs",
    "build:snapshot": "node --env-file-if-exists=.env.local scripts/required/fetch-snapshots.mjs",
    "build:graph": "node scripts/required/build-graph.mjs",
    "build:rag": "node --env-file-if-exists=.env.local scripts/aux/build-rag.mjs",
    "build:history": "node scripts/required/build-history.mjs",
    "build:manifest": "node scripts/required/build-manifest.mjs",
    "build:at": "node --env-file-if-exists=.env.local scripts/required/build-at.mjs",
    "build:ts": "tsc -b",
    "build": "pnpm build:index && pnpm build:glossary && pnpm build:addresses && pnpm build:snapshot && pnpm build:graph && pnpm build:manifest && pnpm run build:ts && vite build",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:snap": "vitest run --config vitest.snap.config.ts",
    "test:snap:update": "vitest run --config vitest.snap.config.ts -u",
    "check:pr": "bash scripts/aux/check-atlas-pr.sh",
    "tva": "bash scripts/aux/tva.sh",
    "query": "node scripts/aux/query-rag.mjs",
    "mcp:atlas": "node mcp-atlas/server.mjs",
    "knip": "knip",
    "pull-atlas": "git submodule update --init --recursive"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@xyflow/react": "^12.10.2",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-traversal": "^0.3.1",
    "katex": "^0.16.45",
    "lunr": "^2.3.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.1.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/hast": "^3.0.4",
    "@types/lunr": "^2.3.7",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "knip": "^6.6.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "viem": "^2.48.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0"
}
