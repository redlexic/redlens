{
  "name": "redlens-mcp",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "npx wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "cf-typegen": "wrangler types",
    "graph:local": "node sync-d1.mjs",
    "graph:remote": "node sync-d1.mjs --remote",
    "vectors:remote": "node sync-vectors.mjs",
    "schema:local": "wrangler d1 execute redlens-atlas --local --file=schema.sql",
    "schema:remote": "wrangler d1 execute redlens-atlas --remote --file=schema.sql",
    "vectorize:create": "wrangler vectorize create redlens-atlas-bge --dimensions=768 --metric=cosine"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@types/node": "^25.6.0",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.83.0"
  }
}
