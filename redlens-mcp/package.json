{
  "name": "redlens-mcp",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "pnpm -w run build:index && pnpm -w run build:addresses && pnpm -w run build:snapshot && pnpm -w run build:graph",
    "deploy": "npx wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "cf-typegen": "wrangler types",
    "graph:local": "node sync-d1.mjs",
    "graph:remote": "node sync-d1.mjs --remote",
    "schema:local": "wrangler d1 execute redlens-atlas --local --file=schema.sql",
    "schema:remote": "wrangler d1 execute redlens-atlas --remote --file=schema.sql"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@types/node": "^25.6.0",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.83.0"
  }
}
